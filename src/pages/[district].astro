---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/NavbarSolid.tsx';
import DistrictHeader from '../components/DistrictHeader.tsx';
import EventGridWrapper from '../components/EventGridWrapper.astro';
import { districtName } from '../lib/districtnames';
import eventsData from '../data/events.json';

export async function getStaticPaths() {
  return Object.keys(eventsData).map(slug => ({ params: { district: slug } }));
}

const { district } = Astro.params;
const events = eventsData[district] || [];
---

<Layout title={districtName(district)}>
  <Navbar client:load />

  <div class="pt-20 md:pt-0 bg-gradient-to-br from-red-600 via-red-400 to-yellow-400 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 py-8">

      <DistrictHeader client:load district={district} />

      {events.length > 0 ? (
        <EventGridWrapper client:load events={events} />
      ) : (
        <p class="text-center py-12 text-white text-xl drop-shadow">No events yet.</p>
      )}
    </div>
  </div>
</Layout>
