---
// src/pages/contact.astro
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/NavbarSolid.tsx";
import ContactCard from "../components/ContactCard.tsx";
import ReactiveHeading from "../components/ReactiveHeading.tsx";
import { contactPage } from "../lib/districtnames.ts";
---

<Layout title={contactPage.title.kn}>
  <Navbar client:load />

  <main class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-orange-50 pt-20 md:pt-0">
    <section class="py-20 px-6 md:px-12 text-center max-w-5xl mx-auto">
      <ReactiveHeading
        client:load
        en={contactPage.title.en}
        kn={contactPage.title.kn}
        class="text-4xl md:text-5xl font-bold text-blue-900 mb-8"
      />
      <p class="text-lg md:text-xl text-gray-700 max-w-4xl mx-auto leading-relaxed mb-16">
        {contactPage.description.kn}
      </p>

      <!-- Cards in single column (row-wise) with generous spacing -->
      <div class="flex flex-col gap-12 md:gap-16 lg:gap-20">
        <ContactCard client:load index={0} />
        <ContactCard client:load index={1} />
        <ContactCard client:load index={2} />
      </div>
    </section>
  </main>
</Layout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Serif+Kannada:wght@400;600;700&display=swap');

  body {
    font-family: 'Noto Serif Kannada', serif;
  }

  .contact-card {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.4);
    box-shadow: 
      0 10px 30px rgba(0, 0, 0, 0.1),
      0 -10px 30px rgba(255, 255, 255, 0.3);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border-radius: 1.5rem; /* Slightly rounded corners */
  }

  .contact-card:hover {
    transform: translateY(-8px);
    box-shadow: 
      0 20px 50px rgba(0, 0, 0, 0.15),
      0 -15px 40px rgba(255, 255, 255, 0.4);
  }
</style>