---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/NavbarSolid.tsx';
import MegaCarousel from '../components/MegaCarousel.tsx';
import MegaEventCard from '../components/MegaEventCard.tsx';
import ReactiveHeading from '../components/ReactiveHeading.tsx';
import { t } from '../lib/districtnames';
---

<Layout title={t("Home","ಮುಖಪುಟ")}>
  <Navbar client:load />

  <main class="pt-20 md:pt-0 bg-[#FFF7E6]">
    <MegaCarousel
      client:load
      images={[
        "/images/mega/hero1.jpg",
        "/images/mega/hero2.jpg",
        "/images/mega/hero3.jpg"
      ]}
      height="h-64 md:h-96"
    />

    <section class="max-w-7xl mx-auto px-4 py-12">
      <ReactiveHeading
        client:load
        en="Past Mega Events"
        kn="ಹಿಂದಿನ ಮೆಗಾ ಕಾರ್ಯಕ್ರಮಗಳು"
        class="text-3xl font-bold text-center mb-8 text-[#C73B3B] drop-shadow"
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <MegaEventCard
          client:load
          slug="poetry-fest"
          titleEn="Grand Kannada Poetry Festival"
          titleKn="ಭವ್ಯ ಕನ್ನಡ ಕಾವ್ಯೋತ್ಸವ"
          image="/images/mega/poetry-thumb.jpg"
        />
        <MegaEventCard
          client:load
          slug="literature-conclave"
          titleEn="Kannada Literature Conclave"
          titleKn="ಕನ್ನಡ ಸಾಹಿತ್ಯ ಸಮಾವೇಶ"
          image="/images/mega/conclave-thumb.jpg"
        />
      </div>
    </section>
  </main>
</Layout>
