---
// src/pages/districts.astro
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/NavbarSolid.tsx";
import DistrictGridWrapper from "../components/DistrictGridWrapper.astro";
import ReactiveHeading from "../components/ReactiveHeading.tsx";
import eventsData from "../data/events.json";
import { t } from "../lib/districtnames";

const districtsWithEvents = Object.keys(eventsData);
---

<Layout title={t("Districts", "ಜಿಲ್ಲೆಗಳು")}>

  <!-- Navbar (black & white) -->
  <Navbar client:load />

  <main class="pt-20 md:pt-0 min-h-screen bg-gray-50">

    <!-- Page Title -->
    <section class="py-16 px-6 text-center">
      <ReactiveHeading
        client:load
        en="Select Your District"
        kn="ಜಿಲ್ಲೆ ಆಯ್ಕೆಮಾಡಿ"
        class="text-4xl md:text-5xl font-bold text-center mb-12 text-gray-900"
      />
    </section>

    <!-- Districts Grid -->
    <section class="max-w-7xl mx-auto px-4 pb-20">
      <DistrictGridWrapper districtsWithEvents={districtsWithEvents} />
    </section>

  </main>

  <!-- Footer (black & white) -->
  <footer class="bg-black text-gray-300 py-12 px-6 md:px-12">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12 text-center md:text-left">
      
      <!-- Left: Brand & Description -->
      <div>
        <h3 class="text-3xl md:text-4xl font-serif font-bold text-white mb-4">
          {t("Sugama Sangeetha", "ಸುಗಮ ಸಂಗೀತ")}
        </h3>
        <p class="text-base leading-relaxed opacity-80 max-w-md mx-auto md:mx-0">
          {t(
            "Celebrating the timeless beauty of Kannada Sugama Sangeetha – a cherished tradition of poetry, melody, and heartfelt expression.",
            "ಕನ್ನಡ ಸುಗಮ ಸಂಗೀತದ ಕಾಲಾತೀತ ಸೌಂದರ್ಯವನ್ನು ಆಚರಿಸುವುದು – ಕಾವ್ಯ, ಸ್ವರ ಮತ್ತು ಹೃದಯಸ್ಪರ್ಶಿ ಅಭಿವ್ಯಕ್ತಿಯ ಪ್ರಿಯ ಪರಂಪರೆ."
          )}
        </p>
        <div class="mt-6 flex justify-center md:justify-start gap-6 text-2xl">
          <a href="#" aria-label="X" class="hover:text-gray-400 transition">𝕏</a>
          <a href="#" aria-label="YouTube" class="hover:text-gray-400 transition">▶️</a>
          <a href="#" aria-label="Instagram" class="hover:text-gray-400 transition">📸</a>
        </div>
      </div>

      <!-- Middle: Quick Links -->
      <div>
        <h4 class="text-xl font-semibold text-white mb-6">
          {t("Quick Links", "ತ್ವರಿತ ಲಿಂಕ್‌ಗಳು")}
        </h4>
        <ul class="space-y-3 text-base">
          <li><a href="/" class="hover:text-gray-400 transition">{t("Home", "ಮುಖಪುಟ")}</a></li>
          <li><a href="/about" class="hover:text-gray-400 transition">{t("About", "ಬಗ್ಗೆ")}</a></li>
          <li><a href="/contact" class="hover:text-gray-400 transition">{t("Contact", "ಸಂಪರ್ಕಿಸಿ")}</a></li>
          <li><a href="/districts" class="hover:text-gray-400 transition">{t("Events", "ಕಾರ್ಯಕ್ರಮಗಳು")}</a></li>
        </ul>
      </div>

      <!-- Right: Contact Info -->
      <div>
        <h4 class="text-xl font-semibold text-white mb-6">
          {t("Contact Us", "ನಮ್ಮನ್ನು ಸಂಪರ್ಕಿಸಿ")}
        </h4>
        <div class="space-y-4 text-base">
          <p class="flex items-center justify-center md:justify-start gap-3">
            <span class="text-2xl">📍</span>
            <span>{t("Bengaluru, Karnataka, India", "ಬೆಂಗಳೂರು, ಕರ್ನಾಟಕ, ಭಾರತ")}</span>
          </p>
          <p class="flex items-center justify-center md:justify-start gap-3">
            <span class="text-2xl">📞</span>
            <a href="tel:+919876543210" class="hover:text-gray-400 transition">+91 98765 43210</a>
          </p>
          <p class="flex items-center justify-center md:justify-start gap-3">
            <span class="text-2xl">✉️</span>
            <a href="mailto:info@sugamasangeetha.org" class="hover:text-gray-400 transition break-all">
              info@sugamasangeetha.org
            </a>
          </p>
        </div>
      </div>

    </div>

    <!-- Copyright -->
    <div class="mt-12 text-center text-sm opacity-70 border-t border-gray-800 pt-6">
      <p>© {new Date().getFullYear()} Sugama Sangeetha | {t("All Rights Reserved", "ಎಲ್ಲ ಹಕ್ಕುಗಳೂ ಕಾದಿರಿಸಲಾಗಿದೆ")}</p>
    </div>
  </footer>
</Layout>