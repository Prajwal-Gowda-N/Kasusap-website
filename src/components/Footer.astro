---
// src/components/Footer.astro
import ReactiveHeading from "./ReactiveHeading.tsx";
import ReactiveText from "./ReactiveText.tsx";
import { t } from "../lib/districtnames";
---

<footer class="bg-black text-gray-300 py-12 px-6 md:px-12">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12 text-center md:text-left">
    
    <!-- Left: Brand & Description -->
    <div>
      <ReactiveHeading
        client:load
        en="Sugama Sangeetha"
        kn="ಸುಗಮ ಸಂಗೀತ"
        class="text-3xl md:text-4xl font-serif font-bold text-white mb-4"
      />

      <ReactiveText
        client:load
        en="Celebrating the timeless beauty of Kannada Sugama Sangeetha – a cherished tradition of poetry, melody, and heartfelt expression."
        kn="ಕನ್ನಡ ಸುಗಮ ಸಂಗೀತದ ಕಾಲಾತೀತ ಸೌಂದರ್ಯವನ್ನು ಆಚರಿಸುವುದು – ಕಾವ್ಯ, ಸ್ವರ ಮತ್ತು ಹೃದಯಸ್ಪರ್ಶಿ ಅಭಿವ್ಯಕ್ತಿಯ ಪ್ರಿಯ ಪರಂಪರೆ."
        class="text-base leading-relaxed opacity-80 max-w-md mx-auto md:mx-0"
      />

      <div class="mt-6 flex justify-center md:justify-start gap-6 text-2xl">
        <a href="#" aria-label="X" class="hover:text-gray-400 transition">𝕏</a>
        <a href="#" aria-label="Instagram" class="hover:text-gray-400 transition">
    <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.245.245 2.695.072 7.053.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.173 4.358 2.623 6.808 6.981 6.981C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.358-.173 6.808-2.623 6.981-6.981.058-1.28.072-1.689.072-4.948 0-3.259-.014-3.667-.072-4.947-.173-4.358-2.623-6.808-6.981-6.981C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zm0 10.162a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 1 0 2.88 1.44 1.44 0 0 1 0-2.88z"/>
    </svg>
  </a>
        <a href="#" aria-label="YouTube" class="hover:text-gray-400 transition">
    <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
      <path d="M23.498 6.186a2.993 2.993 0 0 0-2.115-2.115C19.505 3.5 12 3.5 12 3.5s-7.505 0-9.383.571a2.993 2.993 0 0 0-2.115 2.115C0 8.064 0 12 0 12s0 3.936.502 5.814a2.993 2.993 0 0 0 2.115 2.115C4.495 20.5 12 20.5 12 20.5s7.505 0 9.383-.571a2.993 2.993 0 0 0 2.115-2.115C24 15.936 24 12 24 12s0-3.936-.502-5.814zM9.75 15.5V8.5l6.5 3.5-6.5 3.5z"/>
    </svg>
  </a>
      </div>
    </div>

    <!-- Middle: Quick Links -->
    <div>
      <ReactiveHeading
        client:load
        en="Quick Links"
        kn="ತ್ವರಿತ ಲಿಂಕ್‌ಗಳು"
        class="text-xl font-semibold text-white mb-6"
      />

      <ul class="space-y-3 text-base">
        <li><a href="/" class="hover:text-gray-400 transition">{t("Home", "ಮುಖಪುಟ")}</a></li>
        <li><a href="/about" class="hover:text-gray-400 transition">{t("About", "ಬಗ್ಗೆ")}</a></li>
        <li><a href="/contact" class="hover:text-gray-400 transition">{t("Contact", "ಸಂಪರ್ಕಿಸಿ")}</a></li>
        <li><a href="/districts" class="hover:text-gray-400 transition">{t("Events", "ಕಾರ್ಯಕ್ರಮಗಳು")}</a></li>
      </ul>
    </div>

    <!-- Right: Contact Info -->
    <div>
      <ReactiveHeading
        client:load
        en="Contact Us"
        kn="ನಮ್ಮನ್ನು ಸಂಪರ್ಕಿಸಿ"
        class="text-xl font-semibold text-white mb-6"
      />

      <div class="space-y-4 text-base">
        <p class="flex items-center justify-center md:justify-start gap-3">
          <span class="text-2xl">📍</span>
          <span>{t("Bengaluru, Karnataka, India", "ಬೆಂಗಳೂರು, ಕರ್ನಾಟಕ, ಭಾರತ")}</span>
        </p>
        <p class="flex items-center justify-center md:justify-start gap-3">
          <span class="text-2xl">📞</span>
          <a href="tel:+919876543210" class="hover:text-gray-400 transition">+91 1233333333</a>
        </p>
        <p class="flex items-center justify-center md:justify-start gap-3">
          <span class="text-2xl">✉️</span>
          <a href="mailto:info@sugamasangeetha.org" class="hover:text-gray-400 transition break-all">
            info@sugamasangeetha.org
          </a>
        </p>
      </div>
    </div>

  </div>

  <!-- Copyright – reactive -->
  <div class="mt-12 text-center text-sm opacity-70 border-t border-gray-800 pt-6">
    <p>
      © {new Date().getFullYear()} Sugama Sangeetha | 
      <ReactiveText
        client:load
        en="All Rights Reserved"
        kn="ಎಲ್ಲ ಹಕ್ಕುಗಳೂ ಕಾದಿರಿಸಲಾಗಿದೆ"
      />
    </p>
  </div>
</footer>